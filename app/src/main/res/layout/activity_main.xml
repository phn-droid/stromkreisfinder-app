<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingTop="32dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:background="?android:colorBackground">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imageHeaderLogo"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:contentDescription="StromkreisFinder Logo"
                android:src="@drawable/ic_stromkreisfinder_logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="StromkreisFinder"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textCurrentView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fachanwendungen"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zurück"
            android:padding="10dp"
            android:scaleType="center"
            android:src="@drawable/ic_header_back_plain"
            android:visibility="invisible" />

        <ImageButton
            android:id="@+id/buttonMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            android:background="@android:color/transparent"
            android:contentDescription="Menü"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_header_menu_plain" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/desktopScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/desktopRootContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            <TextView
                style="@style/PanelTitle"
                android:text="Fachanwendungen" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="Wähle eine Teilapp aus. Derzeit ist nur Stromkreise aktiv; die weiteren Fachmodule sind vorbereitet."
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:id="@+id/cardStromkreise"
                        style="@style/ModuleCardActive"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚡"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="30sp" />

                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Stromkreise" />

                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="FI, LS, Aktor, Leitung" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardZaehlerkasten"
                        style="@style/ModuleCardDisabled"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="▣"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="30sp" />

                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Zählerkasten" />

                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="vorbereitet" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:id="@+id/cardBalkonkraftwerk"
                        style="@style/ModuleCardDisabled"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="☀"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="30sp" />

                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Balkonkraftwerk" />

                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="vorbereitet" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardNetzwerk"
                        style="@style/ModuleCardDisabled"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⌁"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="30sp" />

                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Netzwerk" />

                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="CAT7 vorbereitet" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardKnx"
                    style="@style/ModuleCardDisabled"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="◇"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="30sp" />

                    <TextView
                        style="@style/ModuleCardTitle"
                        android:text="KNX-Verkabelung" />

                    <TextView
                        style="@style/ModuleCardSubtitle"
                        android:text="vorbereitet" />
                </LinearLayout>
            </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/desktopStromkreiseContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/PanelTitle"
                    android:text="Stromkreise" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Suchen und Auswertungen der Stromkreis-Datenbank."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/cardStromkreissuche"
                        style="@style/ModuleCard"
                        android:orientation="vertical">
                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Stromkreissuche" />
                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="Etage, Raum und Verbraucher suchen" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardVerbrauchersuche"
                        style="@style/ModuleCard"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Verbrauchersuche" />
                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="Aktor und Kanal suchen" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardRaumsuche"
                        style="@style/ModuleCard"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Raumsuche" />
                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="FI und LS suchen" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardLeitungssuche"
                        style="@style/ModuleCard"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Leitungssuche" />
                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="Leitungsbezeichnung suchen" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardDarkmode"
                        style="@style/ModuleCard"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Darkmode umschalten" />
                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="Hell/Dunkel für die App wechseln" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardStromkreiseBack"
                        style="@style/ModuleCard"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/ModuleCardTitle"
                            android:text="Zurück" />
                        <TextView
                            style="@style/ModuleCardSubtitle"
                            android:text="zur Übersicht der Fachanwendungen" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/resultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:id="@+id/panelResultStromkreis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Stromkreis"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingEnd="10dp">

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabel"
                                    android:text="FI: "
                                    android:textColor="#9FD7C9" />
                                <TextView android:id="@+id/valueFi" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabel"
                                    android:text="LS: "
                                    android:textColor="#E8C94F" />
                                <TextView android:id="@+id/valueSicherung" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabel"
                                    android:text="Aktor: "
                                    android:textColor="#C48AD9" />
                                <TextView android:id="@+id/valueAktor" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabel"
                                    android:text="Kanal: "
                                    android:textColor="#89C6F1" />
                                <TextView android:id="@+id/valueKanal" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabel"
                                    android:text="Phase: "
                                    android:textColor="#F0C56A" />
                                <TextView android:id="@+id/valuePhase" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabel"
                                    android:text="Aktiv: "
                                    android:textColor="#B5C1C6" />
                                <TextView android:id="@+id/valueAktiv" style="@style/ResultInlineValue" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabelRight" android:text="Block: " />
                                <TextView android:id="@+id/valueBlock" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabelRight" android:text="Klemme: " />
                                <TextView android:id="@+id/valueKlemme" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabelRight" android:text="Leitung: " />
                                <TextView android:id="@+id/valueLeitung" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabelRight" android:text="Kabelart: " />
                                <TextView android:id="@+id/valueKabelart" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabelRight" android:text="Raumnr.: " />
                                <TextView android:id="@+id/valueRaumnr" style="@style/ResultInlineValue" />
                            </LinearLayout>

                            <LinearLayout
                        style="@style/ResultInlineRow"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                                <TextView style="@style/ResultInlineLabelRight" android:text="Blatt: " />
                                <TextView android:id="@+id/valueBlatt" style="@style/ResultInlineValue" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/ResultInlineRow"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView style="@style/ResultInlineLabelWide" android:text="Bemerkungen: " />
                        <TextView android:id="@+id/valueBemerkung" style="@style/ResultInlineValue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textErgebnis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Bitte Auswahl treffen und auf Suchen tippen."
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="14sp"
                        android:text="Daten aus Datenbank geladen." />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelResultVerbrauchersuche"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textErgebnisVerbrauchersuche"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Bitte Auswahl treffen und auf Suchen tippen."
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/valueVerbraucherSucheErgebnis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelResultRaumsuche"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textErgebnisRaumsuche"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Bitte Auswahl treffen und auf Suchen tippen."
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/valueRaumSucheErgebnis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panelResultLeitungssuche"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textErgebnisLeitungssuche"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Bitte Auswahl treffen und auf Suchen tippen."
                        android:textColor="?android:textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/valueLeitungSucheErgebnis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelSearchStromkreis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/FormLabel"
                    android:text="Etage" />

                <Spinner
                    android:id="@+id/spinnerEtage"
                    style="@style/FormSpinner" />

                <TextView
                    style="@style/FormLabel"
                    android:text="Raum" />

                <Spinner
                    android:id="@+id/spinnerRaum"
                    style="@style/FormSpinner" />

                <TextView
                    style="@style/FormLabel"
                    android:text="Verbraucher" />

                <Spinner
                    android:id="@+id/spinnerVerbraucher"
                    style="@style/FormSpinner" />

                <Button
                    android:id="@+id/buttonSuchen"
                    style="@style/SearchButton"
                    android:text="Suchen" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelSearchVerbraucher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/FormLabel"
                    android:text="Aktor" />

                <Spinner
                    android:id="@+id/spinnerAktor"
                    style="@style/FormSpinner" />

                <TextView
                    style="@style/FormLabel"
                    android:text="Kanal" />

                <Spinner
                    android:id="@+id/spinnerKanalVerbrauchersuche"
                    style="@style/FormSpinner" />

                <Button
                    android:id="@+id/buttonVerbraucherSuchen"
                    style="@style/SearchButton"
                    android:text="Suchen" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelSearchRaum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/FormLabel"
                    android:text="FI" />

                <Spinner
                    android:id="@+id/spinnerFiRaumsuche"
                    style="@style/FormSpinner" />

                <TextView
                    style="@style/FormLabel"
                    android:text="LS" />

                <Spinner
                    android:id="@+id/spinnerLsRaumsuche"
                    style="@style/FormSpinner" />

                <Button
                    android:id="@+id/buttonRaumSuchen"
                    style="@style/SearchButton"
                    android:text="Suchen" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelSearchLeitung"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/FormLabel"
                    android:text="Leitung" />

                <Spinner
                    android:id="@+id/spinnerLeitungPrefix"
                    style="@style/FormSpinner" />

                <TextView
                    style="@style/FormLabel"
                    android:text="Nummer / Rest" />

                <Spinner
                    android:id="@+id/spinnerLeitungSuffix"
                    style="@style/FormSpinner" />

                <Button
                    android:id="@+id/buttonLeitungSuchen"
                    style="@style/SearchButton"
                    android:text="Suchen" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelCsvImport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/PanelTitle"
                    android:text="CSV importieren" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Import für die aktuell aktive Fachanwendung Stromkreise."
                    android:textColor="?android:textColorSecondary" />

                <Button
                    android:id="@+id/buttonCsvImport"
                    style="@style/SearchButton"
                    android:text="CSV auswählen" />

                <TextView
                    android:id="@+id/textCsvImportStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Noch keine CSV importiert."
                    android:textColor="?android:textColorPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/PanelTitle"
                    android:text="Info" />

                <TextView
                    android:id="@+id/infoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="StromkreisFinder"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="15sp" />
            </LinearLayout>

            </LinearLayout>
    </ScrollView>
</LinearLayout>
